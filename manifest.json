{
    "manifest_version": 3,
    "name": "QuickSummarizer",
    "version": "0.2",
    "permissions": ["storage"],
    "host_permissions": ["https://generativelanguage.googleapis.com/*"],
    "action": {
        "default_popup": "poptions.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["script.js"],
            "css": ["styles.css"]
        }
    ]
}